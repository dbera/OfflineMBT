    <bpmn2:startEvent bpmn4s:ctxInit="ctx := Context {&#10;  id = 0,&#10;  nested = Nested {&#10;    id = 0,&#10;    mix = &quot;My Init Value&quot;,&#10;    symbol = &quot;My Init Symbol&quot;&#10;  }&#10;}" id="Event_0wdp3sm">
