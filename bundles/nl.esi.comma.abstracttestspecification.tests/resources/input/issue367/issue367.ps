import "issue367.types"
specification issue367
{
    system Root
    {
        //inputs
        
        //outputs
    
        local
        Input	d1
        Input	d4
        Report	d2
        Report	d3
        UNIT	Event_052akh2
        UNIT	Event_07r9aer
        UNIT	Flow_01xqgnw
        UNIT	Flow_12ridhf
        UNIT	Flow_1u9fpei
        UNIT	Flow_1jw2qfx
    
        init
        Event_052akh2 := UNIT { unit = 0 }
    
    
        desc "Root_Model"
        
        action			T1
        element-label	"T1"
        case			default step-type "Dummy" action-type COMPOSE
        with-inputs		Event_052akh2
        produces-outputs	Flow_01xqgnw suppress
        updates:
            Flow_01xqgnw := Event_052akh2
        produces-outputs	d1 symbolic-link
        updates:
            d1 := Input {
             id = 0,
             input1 = "ONE"
            }
        
        action			T5
        element-label	"T5"
        case			default step-type "Dummy" action-type RUN
        with-inputs		Flow_1jw2qfx, d4
        produces-outputs	Event_07r9aer suppress
        updates:
            Event_07r9aer := Flow_1jw2qfx
        
        action			T4
        element-label	"T4"
        case			default step-type "Dummy" action-type COMPOSE
        with-inputs		Flow_1u9fpei, d3
        produces-outputs	Flow_1jw2qfx suppress
        updates:
            Flow_1jw2qfx := Flow_1u9fpei
        produces-outputs	d4
        references {
            z: d4.input1 := d3.output1
        } symbolic-link
        updates:
            d4 := Input { id = d3.id }
        
        action			T2
        element-label	"T2"
        case			default step-type "Dummy" action-type RUN
        with-inputs		Flow_01xqgnw, d1
        produces-outputs	Flow_12ridhf suppress
        updates:
            Flow_12ridhf := Flow_01xqgnw
        produces-outputs	d2 symbolic-link
        updates:
            d2 := Report { id = d1.id }
        
        action			T3
        element-label	"T3"
        case			default step-type "Dummy" action-type COMPOSE
        with-inputs		Flow_12ridhf, d2
        produces-outputs	Flow_1u9fpei suppress
        updates:
            Flow_1u9fpei := Flow_12ridhf
        produces-outputs	d3
        references {
            x: d3.output1 := d2.output1
            y: d3.output2 := d2.output2
        } symbolic-link
        updates:
            d3 := Report { id = d2.id }
    
        element-labels ["Root"]
    }
    
	SUT-blocks Root Root
	depth-limits 300
	state-limits 1000
	num-tests 1
}
