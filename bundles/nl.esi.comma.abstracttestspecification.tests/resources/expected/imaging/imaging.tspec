Test-Purpose    "The purpose of this test is..."
Background      "The background of this test is..."

test-sequence from_abstract_to_concrete {
    test_single_sequence
}

step-sequence test_single_sequence {

step-id    step_SupervisonModelSupervisionTemperatureHandler_ExecuteSetTemp_default_0
step-type  SetTemperature
step-input SupervisonModelSupervisionTemperatureHandlerInput
ref-to-step-output
    SupervisonModelSupervisionTemperatureHandlerInput.TempCMD.cmd_type := TempEnum::SET
    SupervisonModelSupervisionTemperatureHandlerInput.TempCMD.id := 0

assertion-id    step_SupervisonModelTemperatureController_CheckTemp_default_0
assertion-type  TempCheck
assertion-input SupervisonModelTemperatureControllerInput
assertion-items {
assertions default { 
    
                x: assert-that(step_SupervisonModelSupervisionTemperatureHandler_ExecuteSetTemp_default_0.output.temp_achieved.temp_val){equal-to 1}
 }
}
ref-to-step-output
    SupervisonModelTemperatureControllerInput.temp_achieved.result := ResponseEnum::OK
    SupervisonModelTemperatureControllerInput.temp_achieved.reqid := 0

