record UNIT {
	int	unit
}

record AcqData {
    int	id
    symbolic real	contrast
    symbolic real	resolution
    symbolic real	signal_to_noise_ratio
}

record AcqReq {
    ImageEnum	cmd_type
    int	id
}

record AcqResp {
    ResponseEnum	result
    int	id
}

record CTX {
    int	id
}

record EquipmentStatus {
    Status	temp_status
    Status	pump_status
    Status	acq_status
}

enum ImageEnum { PREPARE START STOP UNPREPARE }

enum ImageQuality { HIGH LOW NA }

record ImgReq {
    ImageEnum	cmd_type
    int	id
    ImageQuality	image_quality
}

record ImgResp {
    ResponseEnum	result
}

record PumpReq {
    VacuumEnum	cmd_type
    int	id
}

record PumpResp {
    ResponseEnum	result
}

enum ResponseEnum { OK NOK }

enum Status { ON OFF PREPARING UNPREPARING }

enum TempEnum { SET RESET }

record TempReq {
    TempEnum	cmd_type
    int	id
}

record TempResp {
    ResponseEnum	result
    symbolic int	temp_val
    int	reqid
}

record VacReq {
    VacuumEnum	cmd_type
    int	id
}

record VacResp {
    ResponseEnum	result
}

enum VacuumEnum { ON OFF }

